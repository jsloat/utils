#!/bin/bash

_shell_config_repo_root() {
  local src="${BASH_SOURCE[0]}"
  while [ -L "$src" ]; do
    local dir
    dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    if [[ $src != /* ]]; then
      src="$dir/$src"
    fi
  done
  cd -P "$(dirname "$src")/.." && pwd
}

__shell_config_root="$(_shell_config_repo_root)"

# Ensure that all new terminal sessions load everything.
# shellcheck disable=SC1090,SC1091
source "$__shell_config_root/bash/bashrc"

unset -f _shell_config_repo_root
unset __shell_config_root

# Silence the bash deprecation warning on terminal start.
export BASH_SILENCE_DEPRECATION_WARNING=1

if [ -x /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi
