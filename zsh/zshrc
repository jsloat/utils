#!/bin/zsh

_shell_config_repo_root() {
  local src="${(%):-%N}"
  while [[ -L "$src" ]]; do
    local dir
    dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    if [[ $src != /* ]]; then
      src="$dir/$src"
    fi
  done
  cd -P "$(dirname "$src")/.." && pwd
}

__shell_config_root="$(_shell_config_repo_root)"
__legacy_config_root="$__shell_config_root/shared-configs/bash-config"

if [[ -e "$__shell_config_root/local/private.sh" ]]; then
  source "$__shell_config_root/local/private.sh"
elif [[ -e "$HOME"/bash_utils/private.sh ]]; then
  source "$HOME"/bash_utils/private.sh
fi

source "$__legacy_config_root"/bash_utils/textFormatting.sh
source "$__legacy_config_root"/bash_utils/common.sh
source "$__legacy_config_root"/bash_utils/macOS.sh
source "$__legacy_config_root"/bash_utils/git.sh
source "$__legacy_config_root"/bash_utils/system.sh
source "$__legacy_config_root"/bash_utils/gpt.sh

autoload -Uz compinit
compinit -i

_prettify_git_branch() {
  git branch 2>/dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/ [\1]/'
}

setopt PROMPT_SUBST
PROMPT=$'\n%F{green}%~\n$(_prettify_git_branch)%f: '

export PATH="/usr/local/bin:$PATH"

unset -f _shell_config_repo_root
unset __shell_config_root
unset __legacy_config_root
