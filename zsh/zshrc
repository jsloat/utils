#!/bin/zsh

_shell_config_repo_root() {
  local src="${(%):-%x}"
  while [[ -L "$src" ]]; do
    local dir
    dir=$(cd -P "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    if [[ $src != /* ]]; then
      src="$dir/$src"
    fi
  done
  cd -P "$(dirname "$src")/.." && pwd
}

__shell_config_root="$(_shell_config_repo_root)"
export UTILS_REPO_PATH="$__shell_config_root"

source "$__shell_config_root"/shared/textFormatting.sh
source "$__shell_config_root"/shared/common.sh
source "$__shell_config_root"/shared/lazy.sh
source "$__shell_config_root"/shared/path.sh
source "$__shell_config_root"/shared/macOS.sh
source "$__shell_config_root"/shared/git.sh
source "$__shell_config_root"/shared/system.sh
source "$__shell_config_root"/shared/gpt.sh

if [[ -e "$__shell_config_root/local/private.sh" ]]; then
  source "$__shell_config_root/local/private.sh"
elif [[ -e "$HOME"/bash_utils/private.sh ]]; then
  source "$HOME"/bash_utils/private.sh
fi

autoload -Uz compinit
compinit -i

setopt AUTO_MENU
setopt COMPLETE_IN_WORD

zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'
zstyle ':completion:*' rehash true

if [[ -f "$HOME/.antidote/antidote.zsh" ]] && [[ -f "$__shell_config_root/zsh/plugins.txt" ]]; then
  source "$HOME/.antidote/antidote.zsh"
  antidote load "$__shell_config_root/zsh/plugins.txt"
fi

autoload -Uz up-line-or-beginning-search down-line-or-beginning-search
zle -N up-line-or-beginning-search
zle -N down-line-or-beginning-search
bindkey '^[[A' up-line-or-beginning-search
bindkey '^[[B' down-line-or-beginning-search
bindkey '^[OA' up-line-or-beginning-search
bindkey '^[OB' down-line-or-beginning-search
bindkey '^P' up-line-or-beginning-search
bindkey '^N' down-line-or-beginning-search

PROMPT='%F{cyan}%~%f %# '

unset -f _shell_config_repo_root
unset __shell_config_root
